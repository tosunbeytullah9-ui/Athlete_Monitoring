# =============================================================
# AthleteIQ — Environment Variables
# Kopyala: cp .env.example .env.local
# ASLA .env.local dosyasını commit etme!
# =============================================================

# ------ Supabase ------
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=xxx

# ------ WHOOP (developer.whoop.com) ------
WHOOP_CLIENT_ID=xxx
WHOOP_CLIENT_SECRET=xxx
WHOOP_REDIRECT_URI=http://localhost:3000/api/wearables/whoop/callback
WHOOP_WEBHOOK_SECRET=xxx

# ------ Polar (admin.polaraccesslink.com) ------
POLAR_CLIENT_ID=xxx
POLAR_CLIENT_SECRET=xxx
POLAR_REDIRECT_URI=http://localhost:3000/api/wearables/polar/callback

# ------ Email (resend.com) ------
RESEND_API_KEY=re_xxx

# ------ App ------
NEXT_PUBLIC_APP_URL=http://localhost:3000
