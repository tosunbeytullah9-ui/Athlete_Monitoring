{
  "expo": {
    "name": "AthleteIQ",
    "slug": "athleteiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "athleteiq",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.athleteiq.app"
    },
    "android": {
      "package": "com.athleteiq.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
